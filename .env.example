DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/trms
GOOGLE_API_KEY=your-google-vision-api-key
MAX_FILE_SIZE_MB=10
OCR_MIN_TEXT_LENGTH=80
OCR_BATCH_SIZE=8
OCR_DPI=200
OCR_MAX_CONCURRENCY=4
CORS_ORIGINS=*
LOG_LEVEL=INFO
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
REQUEST_TIMEOUT_SECONDS=20
REQUEST_RETRIES=3
REQUEST_BACKOFF_FACTOR=0.5
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
JWT_SECRET=change-me
JWT_ALGORITHM=HS256

BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@trms.com
BREVO_SENDER_NAME=TRMS Recruitment
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-70b-versatile
SKILLS_LLM_ENABLED=true
CERTIFICATIONS_LLM_ENABLED=true
